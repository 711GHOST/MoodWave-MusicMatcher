NODE_ENV=development
PORT=3001

# Leave empty to run a self-contained in-memory MongoDB for local dev,
# or provide a MongoDB connection string (e.g. MongoDB Atlas) for persistence.
MONGODB_URI=

# Use a long, random secret in production. Never commit real secrets.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CLIENT_ORIGIN=http://localhost:3000

SEED_ON_START=false
